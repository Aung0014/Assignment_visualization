{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Median Household Income by State (2022)",
    "subtitle": "Monthly household income in Malaysian Ringgit (MYR)",
    "fontSize": 16,
    "subtitleFontSize": 10,
    "anchor": "start",
    "offset": 2
  },
  "width": 500,
  "height": 400,
  "data": {
    "url": "data/population_clean.csv"
  },
  "transform": [
    {
      "calculate": "datum.state == 'Putrajaya' ? 'WP Putrajaya' : datum.state == 'Kuala Lumpur' ? 'WP K Lumpur' : datum.state == 'Labuan' ? 'WP Labuan' : datum.state == 'Penang' ? 'Pulau Pinang' : datum.state",
      "as": "matched_state"
    }
  ],
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/mptwaktusolat/jakim.geojson/master/malaysia.state.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 0.5
      },
      "encoding": {
        "color": {
          "value": "#f5f5f5"
        }
      }
    },
    {
      "transform": [
        {
          "lookup": "matched_state",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/mptwaktusolat/jakim.geojson/master/malaysia.state.geojson",
              "format": {
                "type": "json",
                "property": "features"
              }
            },
            "key": "properties.name",
            "fields": [
              "geometry"
            ]
          }
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 0.5
      },
      "encoding": {
        "shape": {
          "field": "geometry",
          "type": "geojson"
        },
        "color": {
          "field": "income_median",
          "type": "quantitative",
          "scale": {
            "scheme": "greens",
            "type": "sequential"
          },
          "legend": {
            "title": "Median Income (MYR)",
            "format": ","
          }
        },
        "tooltip": [
          {
            "field": "state",
            "title": "State"
          },
          {
            "field": "income_median",
            "title": "Median Income (MYR)",
            "format": ","
          },
          {
            "field": "income_mean",
            "title": "Mean Income (MYR)",
            "format": ","
          }
        ]
      }
    }
  ],
  "projection": {
    "type": "mercator"
  },
  "config": {
    "view": {
      "stroke": null,
      "continuousWidth": 500,
      "continuousHeight": 400
    },
    "padding": {
      "left": 2,
      "right": 2,
      "top": 2,
      "bottom": 2
    }
  }
}